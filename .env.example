# ============================================================
# Project X — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# ── RAGFlow Infrastructure Passwords ────────────────────────
# SECURITY: Change ALL of these before any non-local deployment!
ELASTIC_PASSWORD=projectx_elastic_changeme
MYSQL_PASSWORD=projectx_mysql_changeme
MYSQL_ROOT_PASSWORD=projectx_root_changeme
MINIO_PASSWORD=projectx_minio_changeme
REDIS_PASSWORD=projectx_redis_changeme

# ── RAGFlow API (set after first launch) ─────────────────────
# 1. Go to http://localhost:80 and register
# 2. Go to Settings → API Keys → create a key
# 3. Paste it here and restart kotaemon container
RAGFLOW_API_KEY=

# 4. After creating a knowledge base in RAGFlow, paste its ID here
#    (or leave blank — the integration will auto-create one)
RAGFLOW_DATASET_ID=

# ── LLM Providers (set at least one) ─────────────────────────
OPENAI_API_KEY=
AZURE_OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ── Ollama (for local/offline models) ────────────────────────
# If Ollama is running on your host machine, use:
KH_OLLAMA_URL=http://host.docker.internal:11434/v1/
